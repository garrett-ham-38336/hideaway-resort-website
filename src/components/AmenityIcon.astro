---
interface Props {
  icon: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
---

<div class="flex flex-col items-center text-center p-6">
  <div class="w-14 h-14 rounded-full bg-lake-blue-light text-lake-blue flex items-center justify-center mb-4 text-2xl">
    <Fragment set:html={icon} />
  </div>
  <h3 class="font-heading text-base font-semibold text-slate-900 mb-1.5">{title}</h3>
  <p class="text-sm text-slate-500 leading-relaxed">{description}</p>
</div>

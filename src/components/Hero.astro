---
interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  bgImage?: string;
  overlay?: boolean;
  size?: "lg" | "md" | "sm";
}

const {
  title,
  subtitle,
  ctaText,
  ctaHref,
  bgImage,
  overlay = true,
  size = "lg",
} = Astro.props;

const heightClass = {
  lg: "min-h-[70vh] md:min-h-[80vh]",
  md: "min-h-[50vh] md:min-h-[60vh]",
  sm: "min-h-[35vh] md:min-h-[40vh]",
}[size];

const titleClass = {
  lg: "text-4xl md:text-5xl lg:text-6xl",
  md: "text-3xl md:text-4xl lg:text-5xl",
  sm: "text-2xl md:text-3xl lg:text-4xl",
}[size];
---

<section
  class:list={[
    "relative flex items-center justify-center text-center text-white",
    heightClass,
  ]}
  style={bgImage ? `background-image: url('${bgImage}'); background-size: cover; background-position: center;` : ""}
>
  {!bgImage && (
    <div class="absolute inset-0 bg-gradient-to-br from-lake-blue-dark via-lake-blue to-forest-green" />
  )}
  {overlay && bgImage && (
    <div class="absolute inset-0 bg-slate-900/50" />
  )}

  <div class="relative z-10 container-site px-6 py-16 max-w-3xl">
    <h1 class:list={["font-heading font-bold leading-tight mb-4", titleClass]}>
      {title}
    </h1>
    {subtitle && (
      <p class="text-lg md:text-xl text-white/90 max-w-2xl mx-auto mb-8 leading-relaxed">
        {subtitle}
      </p>
    )}
    {ctaText && ctaHref && (
      <a href={ctaHref} class="btn btn-cta btn-lg">
        {ctaText}
      </a>
    )}
  </div>
</section>

---
interface Props {
  title: string;
  subtitle?: string;
  align?: "center" | "left";
}

const { title, subtitle, align = "center" } = Astro.props;
---

<div class:list={["mb-10 md:mb-12", align === "center" && "text-center"]}>
  <h2 class="font-heading text-2xl md:text-3xl lg:text-4xl font-bold text-slate-900 mb-3">
    {title}
  </h2>
  {subtitle && (
    <p class:list={[
      "text-base md:text-lg text-slate-500 leading-relaxed",
      align === "center" && "max-w-2xl mx-auto",
    ]}>
      {subtitle}
    </p>
  )}
</div>

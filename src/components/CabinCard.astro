---
import type { Cabin } from "../data/cabins";
import { getPhotosForCabin } from "../data/photos";

interface Props {
  cabin: Cabin;
}

const { cabin } = Astro.props;
const photos = getPhotosForCabin(cabin.slug);
const heroUrl = photos ? photos.card : null;
---

<article class="group bg-white rounded-lg shadow-sm hover:shadow-md transition-all duration-300 overflow-hidden hover:-translate-y-0.5">
  <a href={`/cabins/${cabin.slug}`} class="block">
    <div class="relative h-52 md:h-56 overflow-hidden bg-slate-200">
      {heroUrl ? (
        <img
          src={heroUrl}
          alt={cabin.name}
          width="600"
          height="400"
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        />
      ) : (
        <div class="w-full h-full bg-gradient-to-br from-lake-blue via-lake-blue-dark to-forest-green flex items-center justify-center text-white/20 text-6xl font-heading">
          {cabin.name.charAt(0)}
        </div>
      )}
      <div class="absolute inset-0 bg-slate-900/0 group-hover:bg-slate-900/10 transition-colors duration-300" />
      {cabin.bookingUrl === null && (
        <span class="absolute top-3 right-3 bg-sunset-gold text-slate-900 text-xs font-heading font-semibold px-2.5 py-1 rounded">
          Coming Soon
        </span>
      )}
      {cabin.petFriendly && (
        <span class="absolute top-3 left-3 bg-forest-green text-white text-xs font-heading font-semibold px-2.5 py-1 rounded">
          Pet Friendly
        </span>
      )}
    </div>
  </a>

  <div class="p-5 md:p-6">
    <a href={`/cabins/${cabin.slug}`} class="no-underline">
      <h3 class="font-heading text-lg md:text-xl font-semibold text-slate-900 mb-1.5 group-hover:text-lake-blue transition-colors">
        {cabin.name}
      </h3>
    </a>

    <!-- Meta -->
    <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-slate-500 mb-3">
      <span>{cabin.bedrooms} {cabin.bedrooms === 1 ? "Bed" : "Beds"}</span>
      <span>{cabin.bathrooms} {cabin.bathrooms === 1 ? "Bath" : "Baths"}</span>
      <span>Sleeps {cabin.sleeps}</span>
    </div>

    <p class="text-sm text-slate-500 leading-relaxed mb-4">
      {cabin.tagline}
    </p>

    <!-- Actions -->
    <div class="flex items-center gap-3">
      <a href={`/cabins/${cabin.slug}`} class="btn btn-primary btn-sm flex-1 text-center">
        View Details
      </a>
      {cabin.bookingUrl && (
        <a
          href={cabin.bookingUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-cta btn-sm"
        >
          Book Now
        </a>
      )}
    </div>
  </div>
</article>

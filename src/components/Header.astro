---
import { site, navigation } from "../data/site";

const currentPath = Astro.url.pathname;
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-slate-300 transition-shadow duration-300"
>
  <div class="container-site flex items-center justify-between h-16 md:h-20">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 no-underline shrink-0">
      <span class="font-heading text-xl md:text-2xl font-bold text-slate-900">
        Hideaway <span class="text-lake-blue">Resort</span>
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-6" aria-label="Main navigation">
      {navigation.map((item) => (
        <a
          href={item.href}
          class:list={[
            "text-[0.9375rem] font-medium no-underline transition-colors duration-200",
            currentPath.startsWith(item.href)
              ? "text-lake-blue"
              : "text-slate-700 hover:text-lake-blue",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- CTA + Mobile Toggle -->
    <div class="flex items-center gap-3">
      <a href="/cabins" class="btn btn-cta btn-sm hidden sm:inline-flex">
        Book Now
      </a>

      <!-- Mobile Hamburger -->
      <button
        id="mobile-menu-toggle"
        type="button"
        class="lg:hidden flex items-center justify-center w-10 h-10 rounded text-slate-700 hover:text-lake-blue hover:bg-slate-100 transition-colors"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden bg-white border-t border-slate-300"
  >
    <nav class="container-site py-4 flex flex-col gap-1" aria-label="Mobile navigation">
      {navigation.map((item) => (
        <a
          href={item.href}
          class:list={[
            "block py-3 px-4 rounded text-base font-medium no-underline transition-colors",
            currentPath.startsWith(item.href)
              ? "text-lake-blue bg-lake-blue-light"
              : "text-slate-700 hover:text-lake-blue hover:bg-slate-100",
          ]}
        >
          {item.label}
        </a>
      ))}
      <a href="/cabins" class="btn btn-cta mt-3 text-center">
        Book Now
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("menu-icon-open");
  const iconClose = document.getElementById("menu-icon-close");

  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.contains("hidden") === false;
    menu?.classList.toggle("hidden");
    iconOpen?.classList.toggle("hidden");
    iconClose?.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(!isOpen));
    toggle.setAttribute("aria-label", isOpen ? "Open menu" : "Close menu");
  });
</script>

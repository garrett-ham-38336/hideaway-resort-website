---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import { site } from "../data/site";
---

<BaseLayout
  title="Contact"
  description="Contact Hideaway Resort — call, email, or visit us on Table Rock Lake in Galena, Missouri."
>
  <Hero
    title="Contact Us"
    subtitle="We're here to help with reservations, questions, or anything you need for your stay."
    size="sm"
  />

  <section class="section-padding bg-white">
    <div class="container-site">
      <div class="grid md:grid-cols-2 gap-10 md:gap-16">

        <!-- Contact Info -->
        <div>
          <h2 class="font-heading text-xl md:text-2xl font-bold text-slate-900 mb-6">
            Get in Touch
          </h2>

          <div class="space-y-6">
            <div>
              <h3 class="font-heading text-sm font-semibold text-slate-500 uppercase tracking-wide mb-2">Phone</h3>
              <a href={`tel:${site.phone}`} class="text-lg font-heading font-semibold text-lake-blue no-underline hover:text-lake-blue-dark">
                {site.phoneDisplay}
              </a>
              <p class="text-sm text-slate-500 mt-1">Available {site.officeHours}</p>
            </div>

            <div>
              <h3 class="font-heading text-sm font-semibold text-slate-500 uppercase tracking-wide mb-2">Email</h3>
              <a href={`mailto:${site.email}`} class="text-base text-lake-blue no-underline hover:text-lake-blue-dark">
                {site.email}
              </a>
            </div>

            <div>
              <h3 class="font-heading text-sm font-semibold text-slate-500 uppercase tracking-wide mb-2">Address</h3>
              <p class="text-base text-slate-700">{site.address.street}</p>
              <p class="text-base text-slate-700">{site.address.city}, {site.address.state} {site.address.zip}</p>
            </div>

            <div>
              <h3 class="font-heading text-sm font-semibold text-slate-500 uppercase tracking-wide mb-2">Follow Us</h3>
              <div class="flex gap-4">
                <a href={site.social.facebook} target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-lake-blue transition-colors no-underline text-sm">Facebook</a>
                <a href={site.social.instagram} target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-lake-blue transition-colors no-underline text-sm">Instagram</a>
                <a href={site.social.youtube} target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-lake-blue transition-colors no-underline text-sm">YouTube</a>
              </div>
            </div>
          </div>

          <!-- Management note -->
          <div class="mt-8 bg-lake-blue-light rounded-lg p-5">
            <p class="text-sm text-slate-700 leading-relaxed">
              Hideaway Resort is professionally managed by
              <strong>Weekender Management</strong>. Our local team handles
              reservations, maintenance, and guest support to ensure your stay
              is perfect.
            </p>
          </div>
        </div>

        <!-- Contact Form -->
        <div>
          <h2 class="font-heading text-xl md:text-2xl font-bold text-slate-900 mb-6">
            Send a Message
          </h2>
          <form class="space-y-5" name="contact" method="POST" data-netlify="true">
            <div>
              <label for="name" class="block text-sm font-medium text-slate-700 mb-1.5">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 rounded border border-slate-300 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-lake-blue focus:border-lake-blue transition-colors"
                placeholder="Your name"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-slate-700 mb-1.5">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded border border-slate-300 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-lake-blue focus:border-lake-blue transition-colors"
                placeholder="you@example.com"
              />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-slate-700 mb-1.5">Phone <span class="text-slate-400">(optional)</span></label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="w-full px-4 py-3 rounded border border-slate-300 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-lake-blue focus:border-lake-blue transition-colors"
                placeholder="(555) 555-5555"
              />
            </div>
            <div>
              <label for="subject" class="block text-sm font-medium text-slate-700 mb-1.5">Subject</label>
              <select
                id="subject"
                name="subject"
                class="w-full px-4 py-3 rounded border border-slate-300 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-lake-blue focus:border-lake-blue transition-colors bg-white"
              >
                <option value="reservation">Reservation Inquiry</option>
                <option value="general">General Question</option>
                <option value="group">Group / Reunion Booking</option>
                <option value="boat-slip">Boat Slip Rental</option>
                <option value="pet">Pet Policy Question</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-slate-700 mb-1.5">Message</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-3 rounded border border-slate-300 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-lake-blue focus:border-lake-blue transition-colors resize-y"
                placeholder="Tell us about your trip plans, dates, group size..."
              ></textarea>
            </div>
            <button type="submit" class="btn btn-primary w-full text-center">
              Send Message
            </button>
          </form>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import CabinCard from "../../components/CabinCard.astro";
import CTABanner from "../../components/CTABanner.astro";
import { cabins } from "../../data/cabins";

const individualCabins = cabins.filter((c) => c.slug !== "rent-a-lake");
const rentALake = cabins.find((c) => c.slug === "rent-a-lake");

const bedroomGroups = [
  { label: "1 Bedroom", count: 1, units: individualCabins.filter((c) => c.bedrooms === 1) },
  { label: "2 Bedroom", count: 2, units: individualCabins.filter((c) => c.bedrooms === 2) },
  { label: "3 Bedroom", count: 3, units: individualCabins.filter((c) => c.bedrooms === 3) },
  { label: "4 Bedroom", count: 4, units: individualCabins.filter((c) => c.bedrooms === 4) },
];
---

<BaseLayout
  title="Cabins"
  description="Browse all 12 lakefront cabins at Hideaway Resort on Table Rock Lake. From cozy 1-bedroom retreats to our 12-guest lodge."
>
  <Hero
    title="Our Cabins"
    subtitle="12 unique cabins on Table Rock Lake — each with its own personality, lake access, and full kitchen."
    size="md"
  />

  <!-- Bedroom Filter -->
  <nav class="sticky top-0 z-20 bg-white border-b border-slate-200 shadow-sm">
    <div class="container-site flex items-center gap-2 py-3 overflow-x-auto">
      <span class="text-sm font-medium text-slate-500 shrink-0">Filter:</span>
      <a href="#all" data-filter="all" class="filter-btn filter-btn-active">All</a>
      {bedroomGroups.map((group) => (
        group.units.length > 0 && (
          <a href={`#${group.count}br`} data-filter={`${group.count}br`} class="filter-btn">
            {group.count} BR
            <span class="text-slate-400 ml-1">({group.units.length})</span>
          </a>
        )
      ))}
    </div>
  </nav>

  {bedroomGroups.map((group) => (
    group.units.length > 0 && (
      <section id={`${group.count}br`} data-bedroom-group={`${group.count}br`} class="section-padding cabin-group" class:list={[group.count % 2 === 0 ? "bg-slate-100" : "bg-white"]}>
        <div class="container-site">
          <h2 class="font-heading text-xl md:text-2xl font-bold text-slate-900 mb-6 md:mb-8">
            {group.label} Cabins
            <span class="text-slate-500 font-normal text-base ml-2">({group.units.length})</span>
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
            {group.units.map((cabin) => (
              <CabinCard cabin={cabin} />
            ))}
          </div>
        </div>
      </section>
    )
  ))}

  {rentALake && (
    <section id="whole-resort" class="section-padding bg-lake-blue-light border-t border-lake-blue/20">
      <div class="container-site">
        <h2 class="font-heading text-xl md:text-2xl font-bold text-slate-900 mb-2">
          Book the Whole Resort
        </h2>
        <p class="text-slate-600 mb-6 md:mb-8 max-w-2xl">
          Want Hideaway Resort all to yourself? Rent-A-Lake gives your group exclusive access to every cabin, the private dock, pool, and all resort amenities.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
          <CabinCard cabin={rentALake} />
        </div>
      </div>
    </section>
  )}

  <CTABanner
    title="Need Help Choosing?"
    subtitle="Call us and we'll help you find the perfect cabin for your group size, budget, and dates."
    ctaText="Contact Us"
    ctaHref="/contact"
  />
</BaseLayout>

<style>
  .filter-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
    white-space: nowrap;
    border: 1px solid #e2e8f0;
    color: #475569;
    background: white;
    transition: all 0.15s ease;
    text-decoration: none;
    cursor: pointer;
  }
  .filter-btn:hover {
    border-color: #94a3b8;
    color: #1e293b;
  }
  .filter-btn-active {
    background: #1e3a5f;
    color: white;
    border-color: #1e3a5f;
  }
  .filter-btn-active:hover {
    background: #15304f;
    color: white;
    border-color: #15304f;
  }
  .cabin-group.hidden-group {
    display: none;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filterBtns = document.querySelectorAll<HTMLAnchorElement>('.filter-btn');
    const groups = document.querySelectorAll<HTMLElement>('.cabin-group');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const filter = btn.dataset.filter;

        // Update active button
        filterBtns.forEach(b => b.classList.remove('filter-btn-active'));
        btn.classList.add('filter-btn-active');

        // Show/hide groups
        if (filter === 'all') {
          groups.forEach(g => g.classList.remove('hidden-group'));
        } else {
          groups.forEach(g => {
            if (g.dataset.bedroomGroup === filter) {
              g.classList.remove('hidden-group');
            } else {
              g.classList.add('hidden-group');
            }
          });
        }
      });
    });
  });
</script>

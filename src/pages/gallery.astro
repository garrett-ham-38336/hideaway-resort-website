---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import CTABanner from "../components/CTABanner.astro";
import { cabins } from "../data/cabins";
import {
  resortPhotos,
  cabinPhotos,
  guestyPhoto,
  type ResortPhoto,
} from "../data/photos";

// Combine resort ground photos (pool, dock, fire pit, grounds, recreation)
const resortGroundsPhotos: ResortPhoto[] = [
  ...resortPhotos.pool,
  ...resortPhotos.dock,
  ...resortPhotos.firePit,
  ...resortPhotos.grounds,
  ...resortPhotos.recreation,
];

// Lake & views photos
const lakePhotos: ResortPhoto[] = resortPhotos.lake;

// Cabin photos — hero shot from each cabin
const cabinGalleryPhotos = cabinPhotos.map((cp) => {
  const cabin = cabins.find((c) => c.slug === cp.slug);
  return {
    url: guestyPhoto(cp.hero, "gallery"),
    alt: cabin ? cabin.name : cp.slug,
  };
});
---

<BaseLayout
  title="Gallery"
  description="Photos of Hideaway Resort's lakefront cabins, private dock, swimming pool, and Table Rock Lake views."
>
  <Hero
    title="Photo Gallery"
    subtitle="Take a virtual tour of Hideaway Resort and Table Rock Lake."
    size="sm"
    bgImage={resortPhotos.lake[2].url}
  />

  <!-- Resort & Grounds -->
  <section class="section-padding bg-white">
    <div class="container-site">
      <SectionHeading
        title="Resort & Grounds"
        subtitle="Our lakefront property, pool, dock, fire pits, and common areas."
      />
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4">
        {resortGroundsPhotos.map((photo, i) => (
          <div
            class:list={[
              "rounded-lg overflow-hidden aspect-[4/3]",
              i === 0 && "md:col-span-2 md:row-span-2 aspect-square",
            ]}
          >
            <img
              src={photo.url}
              alt={photo.alt}
              width="800"
              height="600"
              loading={i < 4 ? "eager" : "lazy"}
              decoding="async"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Lake & Views -->
  <section class="section-padding bg-slate-100">
    <div class="container-site">
      <SectionHeading
        title="Lake & Views"
        subtitle="Table Rock Lake sunsets, bluff views, and water activities."
      />
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4">
        {lakePhotos.map((photo, i) => (
          <div
            class:list={[
              "rounded-lg overflow-hidden aspect-[4/3]",
              i === 0 && "md:col-span-2 md:row-span-2 aspect-square",
            ]}
          >
            <img
              src={photo.url}
              alt={photo.alt}
              width="800"
              height="600"
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Cabins -->
  <section class="section-padding bg-white">
    <div class="container-site">
      <SectionHeading
        title="Our Cabins"
        subtitle="Interior and exterior shots of our lakefront cabins."
      />
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4">
        {cabinGalleryPhotos.map((photo, i) => (
          <div class="rounded-lg overflow-hidden aspect-[4/3] relative group">
            <img
              src={photo.url}
              alt={photo.alt}
              width="800"
              height="600"
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-3">
              <span class="text-white text-sm font-heading font-semibold">{photo.alt}</span>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/cabins" class="btn btn-primary">View All Cabins</a>
      </div>
    </div>
  </section>

  <!-- #WeLoveHideaway -->
  <section class="section-padding bg-lake-blue-light">
    <div class="container-site text-center">
      <h2 class="font-heading text-2xl md:text-3xl font-bold text-slate-900 mb-3">
        #WeLoveHideaway
      </h2>
      <p class="text-base text-slate-700 max-w-xl mx-auto mb-6">
        Share your Hideaway Resort memories on social media with
        <strong>#WeLoveHideaway</strong> and your photos may be featured here!
      </p>
      <div class="flex justify-center gap-4">
        <a href="https://instagram.com/weekendermanagement/" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
          Follow on Instagram
        </a>
        <a href="https://facebook.com/weekendermanagement" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
          Follow on Facebook
        </a>
      </div>
    </div>
  </section>

  <CTABanner />
</BaseLayout>
